                    <div class="bg-gray-200 rounded-3xl overflow-hidden banner-clip border-4 border-white">
                        <img src="Coklat Krem dan Hijau Modern Minuman Boba Segar Banner Vertikal_20260310_100521_0000.jpg" alt="Boba Banner" class="w-full h-auto" onerror="this.src='https://via.placeholder.com/400x800?text=Banner+Boba+Wulan+Novia'">
                    </div>
                    <!-- Accent floating elements -->
                    <div class="absolute -top-6 -right-6 bg-white p-4 rounded-2xl shadow-xl animate-bounce">
                        <p class="text-xs font-bold text-center">Terlaris! <br> <span class="text-teal-custom text-lg">Rp 5rb</span></p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Menu Section -->
    <section id="menu" class="py-20 bg-white">
        <div class="container mx-auto px-4">
            <div class="text-center mb-16">
